# Neon Postgres — pooled connection string from neon.tech dashboard
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Clerk — from clerk.com dashboard → API Keys
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# Clerk webhook signing secret — from clerk.com dashboard → Webhooks
CLERK_WEBHOOK_SECRET=whsec_xxxx

# Cloudflare R2 — from dash.cloudflare.com → R2
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=wayfare-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx

# Mapbox — secret token from account.mapbox.com → Access tokens (must be secret, not public)
MAPBOX_SECRET_TOKEN=sk.eyJ...

# Mapbox — public token for client-side map rendering (from account.mapbox.com → Access tokens)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_mapbox_token_here

# Inngest — from app.inngest.com → Event keys / Signing keys
# Local dev: set EVENT_KEY=local, leave SIGNING_KEY empty
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=signkey-xxxx

# Demo trip — hardcoded UUID for the public /demo route seed data
DEMO_TRIP_ID=3a4b5c6d-7e8f-4a1b-8c2d-9e0f1a2b3c4d

# App URL — used for absolute OG image URLs in production (set to your Vercel domain)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
